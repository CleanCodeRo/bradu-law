<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  RewriteCond %{HTTPS} off [OR]
  RewriteCond %{HTTP_HOST} !^www\.bradu-law\.ro [NC]
  RewriteRule ^(.*)$ https://www.bradu-law.ro/$1 [L,R=301]

  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME} !-l
  RewriteRule . /index.html [L]
</IfModule>

<IfModule mod_headers.c>
    <Files "__manifest">
        ForceType application/json
    </Files>
    Header always unset X-Powered-By
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Cross-Origin-Opener-Policy "same-origin-allow-popups"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
    Header always set Content-Security-Policy "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'self'; form-action 'self'; style-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com; script-src 'self' 'unsafe-inline' 'wasm-unsafe-eval' 'unsafe-eval' https://kit.fontawesome.com https://www.googletagmanager.com; img-src 'self' data: blob: https://upload.wikimedia.org https://www.googletagmanager.com https://www.google.com https://ad.doubleclick.net; font-src 'self' data: https://cdnjs.cloudflare.com https://ka-f.fontawesome.com; connect-src 'self' https://maps.geoapify.com https://kit.fontawesome.com https://ka-f.fontawesome.com https://www.googletagmanager.com https://www.google-analytics.com https://region1.google-analytics.com https://www.google.com https://ad.doubleclick.net; frame-src 'self' https://www.googletagmanager.com; worker-src 'self' blob:; child-src 'self' blob:; manifest-src 'self'"
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(), usb=(), interest-cohort=()"
</IfModule>
